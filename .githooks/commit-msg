#!/bin/bash
# Commit message hook for Where project
# Enforces commit message format: type: short description

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

COMMIT_MSG_FILE=$1
FIRST_LINE=$(head -n1 "$COMMIT_MSG_FILE")

# Allow merge commits
if echo "$FIRST_LINE" | grep -qE "^Merge "; then
    exit 0
fi

# Pattern: type: description
PATTERN='^(feat|fix|chore|test|docs|refactor): .+'

if ! echo "$FIRST_LINE" | grep -qE "$PATTERN"; then
    echo -e "${RED}BLOCKED:${NC} Commit message does not follow project format."
    echo ""
    echo "Required format: type: short description"
    echo ""
    echo "Valid types:"
    echo "  feat     → new feature"
    echo "  fix      → bug fix"
    echo "  chore    → data, config, dependencies, setup"
    echo "  test     → adding or updating tests"
    echo "  docs     → documentation only"
    echo "  refactor → code change with no behaviour change"
    echo ""
    echo "Your message was:"
    echo "  $FIRST_LINE"
    echo ""
    echo "See docs/engineering.md for examples."
    exit 1
fi

exit 0
